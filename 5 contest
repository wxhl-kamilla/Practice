import sys


def solve():
    input_data = sys.stdin.read().split()
    if not input_data:
        return

    n = int(input_data[0])
    k = int(input_data[1])

    MOD = 10**9 + 7

    dp = [0] * (n + 1)
    dp[0] = 1

    mONESY = 0

    for i in range(1, n + 1):
        mONESY = (mONESY + dp[i - 1]) % MOD

        if i > k:
            mONESY = (mONESY - dp[i - k - 1] + MOD) % MOD

        dp[i] = mONESY

    print(dp[n])


if __name__ == "__main__":
    solve()
